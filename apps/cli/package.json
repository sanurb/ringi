{
  "name": "@sanurb/ringi",
  "version": "0.3.2",
  "description": "Local-first code review tool for AI-generated changes — CLI and MCP server",
  "homepage": "https://github.com/sanurb/ringi#readme",
  "bugs": {
    "url": "https://github.com/sanurb/ringi/issues"
  },
  "license": "MIT",
  "author": "sanurb",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanurb/ringi.git",
    "directory": "apps/cli"
  },
  "bin": {
    "ringi": "dist/cli.mjs"
  },
  "files": [
    "dist",
    "server",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "exports": {
    "./mcp": {
      "import": "./dist/mcp.mjs"
    }
  },
  "scripts": {
    "dev": "npx tsx src/cli/main.ts",
    "build": "tsdown",
    "build:server": "node scripts/copy-server.mjs",
    "test": "vp test run",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm build && pnpm build:server"
  },
  "dependencies": {
    "effect": "catalog:"
  },
  "devDependencies": {
    "@ringi/core": "workspace:*",
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
