{
  "name": "@sanurb/ringi",
  "version": "0.2.0",
  "private": true,
  "description": "Local-first code review tool for AI-generated changes — CLI, Web UI, and MCP server",
  "homepage": "https://github.com/sanurb/ringi#readme",
  "bugs": {
    "url": "https://github.com/sanurb/ringi/issues"
  },
  "license": "MIT",
  "author": "sanurb",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanurb/ringi.git"
  },
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @ringi/web dev",
    "dev:cli": "pnpm --filter @ringi/cli dev",
    "build": "pnpm --filter @ringi/web build",
    "build:cli": "pnpm --filter @ringi/cli build",
    "build:all": "pnpm build:cli && pnpm build",
    "preview": "pnpm --filter @ringi/web preview",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "oxlint --type-aware --type-check",
    "lint:fix": "oxlint --type-aware --type-check --fix",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "deps": "pnpm dlx taze@latest -Ilw",
    "deps:major": "pnpm dlx taze@latest major -Ilw",
    "tanstack": "pnpm dlx @tanstack/cli@latest",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "lefthook": "^2.1.4",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.4",
    "typescript": "^5.9.3",
    "ultracite": "7.3.2"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "packageManager": "pnpm@10.32.1"
}
