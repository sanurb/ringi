{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "warn",
    "suspicious": "warn",
    "perf": "warn"
  },
  "plugins": [
    "eslint",
    "unicorn",
    "typescript",
    "react",
    "jsx-a11y",
    "import",
    "jsdoc",
    "promise"
  ],
  "jsPlugins": ["./eslint-plugins/ringi-no-vi-mock-plugin.js"],
  "rules": {
    "react-in-jsx-scope": "off",
    "eslint/no-shadow": "off",
    "eslint/no-await-in-loop": "off",
    "eslint/eqeqeq": "off",
    "typescript/no-non-null-assertion": "off",
    "typescript/consistent-type-imports": "off",
    "typescript/no-explicit-any": "off",
    "eslint/no-nested-ternary": "off",
    "oxc/no-barrel-file": "off",
    "eslint/func-style": "off",
    "eslint/no-use-before-define": "off",
    "eslint/require-await": "off",
    "eslint/no-plusplus": "off",
    "eslint/no-eq-null": "off",
    "eslint/no-inline-comments": "off",
    "eslint/no-negated-condition": "off",
    "eslint/max-classes-per-file": "off",
    "eslint/func-names": "off",
    "eslint/sort-keys": "off",
    "eslint/no-void": "off",
    "eslint/no-warning-comments": "off",
    "eslint/complexity": "off",
    "eslint-plugin-react-perf/jsx-no-new-function-as-prop": "off",
    "eslint-plugin-import/first": "off",
    "eslint-plugin-promise/prefer-await-to-then": "off",
    "eslint-plugin-promise/prefer-await-to-callbacks": "off",
    "eslint-plugin-promise/prefer-catch": "off",
    "eslint-plugin-promise/avoid-new": "off",
    "eslint-plugin-unicorn/prefer-add-event-listener": "off",
    "eslint-plugin-unicorn/prefer-structured-clone": "off",
    "eslint-plugin-unicorn/consistent-function-scoping": "off",
    "eslint-plugin-unicorn/no-useless-switch-case": "off",
    "eslint-plugin-unicorn/no-nested-ternary": "off",
    "eslint-plugin-unicorn/no-immediate-mutation": "off",
    "eslint-plugin-unicorn/filename-case": "off",
    "eslint-plugin-react-hooks/rules-of-hooks": "off",
    "eslint-plugin-jsx-a11y/click-events-have-key-events": "off",
    "eslint-plugin-jsx-a11y/prefer-tag-over-role": "off",
    "eslint-plugin-jsdoc/check-tag-names": "off",
    "eslint-plugin-react/no-danger": "off",
    "eslint-plugin-react/no-clone-element": "off",
    "eslint-plugin-react/no-array-index-key": "off",
    "eslint-plugin-react/jsx-no-constructed-context-values": "off",
    "eslint-plugin-import/no-named-as-default-member": "off",
    "ringi/no-vi-mock": "error"
  },
  "ignorePatterns": [
    "dist",
    "node_modules",
    "pnpm-lock.yaml",
    "*.tsbuildinfo",
    "**/routeTree.gen.ts"
  ]
}
